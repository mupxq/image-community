# 数据库
DATABASE_URL=postgresql://coconut:coconut_dev@localhost:5432/coconut_dev
TEST_DATABASE_URL=postgresql://coconut:coconut_dev@localhost:5432/coconut_test

# JWT
JWT_SECRET=coconut-jwt-secret-change-in-production

# 服务端口
PORT=3000
NODE_ENV=development

# 火山引擎 / 豆包
VOLCENGINE_API_KEY=
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_IMAGE_MODEL=doubao-seedream-5-0-260128
VOLCENGINE_TEXT_MODEL=Doubao-Seed-2.0-lite

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_TEXT_MODEL=gpt-4o-mini

# 通用
DEFAULT_AI_PROVIDER=mock
